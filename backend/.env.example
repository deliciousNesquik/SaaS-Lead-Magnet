# ============================================================
# КОНФИГУРАЦИЯ СЕРВЕРА
# Скопируйте в .env и заполните своими значениями
# ============================================================
# --- Express сервер ---
PORT=3001
NODE_ENV=development
# --- JWT ---
# Генерация: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30d
# --- SQLite ---
# Путь к файлу базы данных (создаётся автоматически)
DATABASE_PATH=./storage/database.sqlite
# --- Telegram Bot ---
# Получить токен: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:AAF_your_bot_token_here
# Ваш Telegram ID для получения уведомлений о новых лидах
# Узнать ID: напишите @userinfobot
TELEGRAM_MANAGER_CHAT_ID=123456789
# Группа/канал куда б��т шлёт уведомления о новых регистрациях (опционально)
# TELEGRAM_CRM_CHAT_ID=-1001234567890
# --- CORS ---
# URL фронтенда (React приложение)
FRONTEND_URL=http://localhost:5173
# --- Хранилище файлов ---
# Папка с шаблонами документов (НЕ в public!)
TEMPLATES_DIR=./storage/templates
# --- Rate limiting ---
# Максимум запросов авторизации с одного IP за 15 минут
AUTH_RATE_LIMIT=10
# --- Логи ---
LOG_LEVEL=debug