{
  "name": "ohranatrud-backend",
  "version": "1.0.0",
  "description": "Backend для ОхранаТруда.PRO — Express + SQLite (sql.js WASM) + Telegram Bot",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:bot": "ts-node-dev --respawn --transpile-only src/bot/telegram.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:bot": "node dist/bot/telegram.js",
    "start:all": "concurrently \"npm run start\" \"npm run start:bot\""
  },
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.30",
    "@types/sql.js": "^1.4.9",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  }
}